{
  "git_panel": {
    "tree_view": true
  },
  "auto_install_extensions": {
    "dockerfile": true,
    "git-firefly": true,
    "html": true,
    "just": true,
    "log": true,
    "make": true,
    "material-icon-theme": true,
    "sql": true,
    "toml": true
  },
  "terminal": {
    "font_family": "FiraCode Nerd Font"
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme"
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "session": {
    "trust_all_worktrees": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "base_keymap": "Cursor",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark"
  }
}
